ENV=development
APP_ENV=
LOG_LEVEL=info

API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000
ADMIN_API_KEY=

DATABASE_URL=postgresql://case_assistant:case_assistant@localhost:5432/case_assistant
CASE_REPOSITORY_BACKEND=postgres
CASE_TABLE_NAME=cases
REDIS_URL=redis://localhost:6379/0
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=email-assistant-evidence
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=email_assistant_evidence
RAG_BACKEND=hybrid
INTEGRATION_RETRY_ATTEMPTS=3
RETRIEVAL_TIMEOUT_SECONDS=5.0

LANGGRAPH_SQLITE_PATH=.logs/langgraph-checkpoints.sqlite
